---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/layouts/Navbar.astro";
import Hero from "../components/sections/Hero.astro";
import Project from "../components/sections/Project.astro";
import Sommelier from "../components/sections/Sommelier.astro";
import Jobs from "../components/sections/Jobs.astro";
import Services from "../components/sections/Services.astro";
import Partners from "../components/sections/Partners.astro";
import Collab from "../components/sections/Collab.astro";
import Contact from "../components/sections/Contact.astro";
import Footer from "../components/sections/Footer.astro";
import { getLocaleFromUrl } from "../i18n";

const locale = getLocaleFromUrl(Astro.url);
---

<Layout>
	<Navbar locale={locale} />
	<main>
		<Hero locale={locale} />
		<Project locale={locale} />
		<Sommelier locale={locale} />
		<Jobs locale={locale} />
		<Services locale={locale} />
		<Partners locale={locale} />
		<Collab locale={locale} />
		<Contact locale={locale} />
	</main>
	<Footer />
</Layout>
