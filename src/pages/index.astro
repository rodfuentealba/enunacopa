  <Jobs/>
	<section id="services" class="section placeholder">
		<div class="container">
			<p class="ph-label">Servicios — próximamente</p>
		</div>
	</section>
	<section id="partners" class="section placeholder">
		<div class="container">
			<p class="ph-label">Partners — próximamente</p>
		</div>
	</section>
	<section id="contact" class="section placeholder">
		<div class="container">
			<p class="ph-label">Contacto — próximamente</p>
		</div>
	</section>
</Layout>

