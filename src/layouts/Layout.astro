---
import '../styles/global.css'
import ClientRouter from 'astro/components/ClientRouter.astro'
import { useTranslations, getLocaleFromUrl } from '../i18n'
import Loader from '../components/Loader.astro'

interface Props {
  title?: string
  description?: string
  lang?: string
}

const locale = getLocaleFromUrl(Astro.url)
const { t } = useTranslations(locale)

const {
  title = t('layout.title'),
  description = t('layout.description'),
  lang = locale,
} = Astro.props

const SITE = Astro.site ?? new URL('https://enunacopa.com')
const path = Astro.url.pathname
const url = new URL(path, SITE).href
const locales = ['es', 'en', 'pt']
const defaultLocale = 'es'
const ogImage = new URL('/og-image.png', SITE).href
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={url} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="x-default" href={new URL('/', SITE).href} />
    {locales.map(l => (
      <link rel="alternate" hreflang={l} href={new URL(`/${l}/`, SITE).href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="En Una Copa" />
    <meta property="og:locale" content={lang} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Camilo Chávez",
      "jobTitle": "Sommelier Internacional",
      "knowsAbout": "Vinos chilenos, cata de vinos, maridaje",
      "url": url,
      "image": ogImage,
      "sameAs": [
        "https://www.linkedin.com/in/camilo-ch%C3%A1vez-ram%C3%ADrez-2b060a94/",
        "https://www.instagram.com/camilocram/"
      ]
    })} />

    <!-- Google Fonts — preconnect primero para reducir latencia -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Allison&family=Alexandria:wght@300;400;500;600;700;800&family=Faustina:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&display=swap"
      media="print" onload="this.media='all'"
    />

    <ClientRouter />
    <title>{title}</title>
    <style>
      ::view-transition-old(lang-switch) {
        animation: 0.25s var(--ease-out) both fade-out-down;
      }
      ::view-transition-new(lang-switch) {
        animation: 0.3s var(--ease-out) both fade-in-up;
      }
      @keyframes fade-out-down {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(6px); }
      }
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(-6px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body>
    <Loader />
    <slot />
  </body>
</html>
