---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  lang?: string
}

const {
  title = 'En Una Copa — Camilo Chávez Sommelier',
  description = 'Portfolio digital de Camilo Chávez, Sommelier Internacional certificado WSET 3.',
  lang = 'es',
} = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts — preconnect primero para reducir latencia -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Allison&family=Alexandria:wght@300;400;500;600;700;800&family=Faustina:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&display=swap"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
