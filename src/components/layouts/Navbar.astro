---
import Logo from '../icons/euc.astro'
import IconSun from '../icons/iconSun.astro'
import IconMoon from '../icons/iconMoon.astro'  
---

<header id="navbar" class="flex flex-row items-center justify-between">
  <!-- Isotipo -->
  <a href="/" class="logo" aria-label="En Una Copa">
    <Logo class="text-pink-600 dark:text-white" />
  </a>

  <!-- Sección activa (centro) — actualizada por scroll spy -->
  <span id="nav-section" class="nav-section" aria-live="polite"></span>

  <!-- Controles -->
  <div class="nav-controls">

    <!-- Selector de idioma -->
    <nav class="lang-nav" aria-label="Idioma">
      <a href="/es" class="lang-btn lang-btn--active" lang="es" hreflang="es">ES</a>
      <a href="/en" class="lang-btn" lang="en" hreflang="en">EN</a>
      <a href="/pt" class="lang-btn" lang="pt" hreflang="pt">PT</a>
    </nav>

    <!-- Dark / Light toggle -->
    <button id="theme-btn" class="icon-btn" aria-label="Cambiar tema">
      <IconSun/>
      <IconMoon/>
    </button>

    <!-- Hamburger (solo mobile) -->
    <button id="menu-btn" class="icon-btn hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-drawer">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

  </div>
</header>

<!-- Nav links — desktop (bajo el header) -->
<nav id="desktop-nav" class="desktop-nav" aria-label="Secciones">
  <a href="#hero"       class="dnav-link" data-section="hero">Inicio</a>
  <a href="#project"    class="dnav-link" data-section="project">Proyecto</a>
  <a href="#sommelier"  class="dnav-link" data-section="sommelier">Sommelier</a>
  <a href="#jobs"       class="dnav-link" data-section="jobs">Experiencia</a>
  <a href="#services"   class="dnav-link" data-section="services">Servicios</a>
  <a href="#partners"   class="dnav-link" data-section="partners">Partners</a>
  <a href="#collab"     class="dnav-link" data-section="collab">Colaboración</a>
  <a href="#contact"    class="dnav-link" data-section="contact">Contacto</a>
</nav>

<!-- Mobile drawer -->
<div id="mobile-drawer" class="drawer" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Menú">
  <div class="drawer-backdrop" id="drawer-backdrop"></div>
  <nav class="drawer-panel">
    <a href="#hero"      class="drawer-link" data-close>Inicio</a>
    <a href="#project"   class="drawer-link" data-close>Proyecto</a>
    <a href="#sommelier" class="drawer-link" data-close>Sommelier</a>
    <a href="#jobs"      class="drawer-link" data-close>Experiencia</a>
    <a href="#services"  class="drawer-link" data-close>Servicios</a>
    <a href="#partners"  class="drawer-link" data-close>Partners</a>
    <a href="#collab"    class="drawer-link" data-close>Colaboración</a>
    <a href="#contact"   class="drawer-link" data-close>Contacto</a>
    <div class="drawer-langs">
      <a href="/es" class="lang-btn lang-btn--active">ES</a>
      <a href="/en" class="lang-btn">EN</a>
      <a href="/pt" class="lang-btn">PT</a>
    </div>
  </nav>
</div>

<style>
/* ─── Header ─────────────────────────────────────────────────── */
#navbar, 
.desktop-nav
{
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

#navbar {
  position: fixed;
  inset-block-start: 0;
  inset-inline: 0;
  z-index: 100;
  height: var(--nav-h);
  padding-inline: clamp(1.25rem, 5vw, 2.5rem);
  border-bottom: 1px solid transparent;
}

#navbar.scrolled,
.desktop-nav.scrolled {
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

/* Sección activa */
.nav-section {
  font-family: var(--font-serif);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: opacity 0.3s;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
  pointer-events: none;
}

/* Controles */
.nav-controls {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  flex-shrink: 0;
}

/* Lang nav */
.lang-nav {
  display: flex;
  align-items: center;
  background: var(--color-bg-2);
  border: 1px solid var(--color-border);
  border-radius: 6px;
  padding: 2px;
  gap: 1px;
}

.lang-btn {
  font-family: var(--font-sans);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-decoration: none;
  padding: 3px 8px;
  border-radius: 4px;
  transition: background 0.15s, color 0.15s;
}
.lang-btn:hover { color: var(--color-text); }
.lang-btn--active {
  background: var(--color-accent);
  color: #fff;
}

/* Icon buttons */
.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: none;
  background: transparent;
  color: var(--color-muted);
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.icon-btn:hover {
  background: var(--color-bg-2);
  color: var(--color-text);
}

.icon {
  width: 17px;
  height: 17px;
}

/* Dark mode icon swap */
.icon-moon { display: none; }
.dark .icon-sun  { display: none; }
.dark .icon-moon { display: block; }

/* Hamburger */
.hamburger {
  flex-direction: column;
  gap: 4px;
  display: none;  /* visible solo en mobile via media query */
}
.bar {
  display: block;
  width: 18px;
  height: 1.5px;
  background: currentColor;
  border-radius: 2px;
  transition: transform 0.25s var(--ease-out), opacity 0.2s;
}
.hamburger[aria-expanded="true"] .bar:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
.hamburger[aria-expanded="true"] .bar:nth-child(2) { opacity: 0; }
.hamburger[aria-expanded="true"] .bar:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

/* ─── Desktop nav ────────────────────────────────────────────── */
.desktop-nav {
  display: none; /* activado en md+ */
  position: fixed;
  top: var(--nav-h);
  inset-inline: 0;
  z-index: 99;
  justify-content: center;
  gap: 2rem;
  padding-block: 0.625rem;
  border-bottom: 1px solid var(--color-border);
}

.dnav-link {
  font-family: var(--font-serif);
  font-size: 0.75rem;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none;
  padding-block: 0.125rem;
  border-bottom: 1.5px solid transparent;
}
.dnav-link:hover,
.dnav-link.active {
  color: var(--color-accent);
  border-bottom-color: var(--color-accent);
  font-weight:600;
}

/* ─── Mobile drawer ──────────────────────────────────────────── */
.drawer {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 200;
  pointer-events: none;
}
.drawer.open {
  pointer-events: all;
}

.drawer-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.5);
  opacity: 0;
  transition: opacity 0.3s;
}
.drawer.open .drawer-backdrop { opacity: 1; }

.drawer-panel {
  position: absolute;
  top: 0; right: 0; bottom: 0;
  width: min(300px, 85vw);
  background: var(--color-surface);
  border-left: 1px solid var(--color-border);
  padding: calc(var(--nav-h) + 2rem) 2rem 2rem;
  transform: translateX(100%);
  transition: transform 0.35s var(--ease-out);
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.drawer.open .drawer-panel { transform: translateX(0); }

.drawer-link {
  font-family: var(--font-sans);
  font-size: 1.375rem;
  font-weight: 500;
  color: var(--color-text);
  text-decoration: none;
  padding: 0.625rem 0;
  border-bottom: 1px solid var(--color-border);
  transition: color 0.15s, padding-left 0.2s var(--ease-out);
}
.drawer-link:hover {
  color: var(--color-accent);
  padding-left: 0.5rem;
}

.drawer-langs {
  display: flex;
  gap: 0.5rem;
  margin-top: auto;
  padding-top: 2rem;
}

/* ─── Responsive ─────────────────────────────────────────────── */
@media (min-width: 768px) {
  .desktop-nav { display: flex; }
}

@media (max-width: 767px) {
  .hamburger { display: flex; }
  .drawer    { display: block; }
  .lang-nav  { display: none; } /* está en el drawer */
}
</style>

<script>
  // ── Dark mode ──────────────────────────────────────────────────────
  document.getElementById('theme-btn')?.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark')
    localStorage.setItem('theme', dark ? 'dark' : 'light')
  })

  // ── Scroll: navbar glass effect ────────────────────────────────────
  const navElements = document.querySelectorAll('#navbar, .desktop-nav');
  const onScroll = () => {
  const isScrolled = window.scrollY > 20;
  navElements.forEach(el => el.classList.toggle('scrolled', isScrolled));
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Scroll spy ─────────────────────────────────────────────────────
  const navSection = document.getElementById('nav-section')!
  const dnavLinks  = document.querySelectorAll<HTMLAnchorElement>('.dnav-link')
  const sections   = document.querySelectorAll<HTMLElement>('section[id]')

  const spy = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return
        const id = e.target.id
        // label central
        const link = document.querySelector<HTMLAnchorElement>(`.dnav-link[data-section="${id}"]`)
        if (link) navSection.textContent = link.textContent ?? ''
        // active en desktop nav
        dnavLinks.forEach((l) => l.classList.toggle('active', l.dataset.section === id))
      })
    },
    { threshold: 0.45 }
  )
  sections.forEach((s) => spy.observe(s))

  // ── Mobile drawer ──────────────────────────────────────────────────
  const menuBtn = document.getElementById('menu-btn')!
  const drawer  = document.getElementById('mobile-drawer')!
  const backdrop = document.getElementById('drawer-backdrop')!

  const openDrawer  = () => { drawer.classList.add('open'); drawer.setAttribute('aria-hidden','false'); menuBtn.setAttribute('aria-expanded','true');  document.body.style.overflow='hidden' }
  const closeDrawer = () => { drawer.classList.remove('open'); drawer.setAttribute('aria-hidden','true');  menuBtn.setAttribute('aria-expanded','false'); document.body.style.overflow='' }

  menuBtn.addEventListener('click', () => drawer.classList.contains('open') ? closeDrawer() : openDrawer())
  backdrop.addEventListener('click', closeDrawer)
  document.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeDrawer))
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer() })
</script>
