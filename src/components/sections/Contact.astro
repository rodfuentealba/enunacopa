---
import Logo from "../icons/euc.astro";
import bgContact from "../../assets/images/bgContact.jpg";
import CalendlyIcon from "../icons/calendly.astro";
---

<section id="contact" class="contact bg-black text-white">
  <div class="contact-inner">
    <!-- Left column: image + brand overlay -->
    <div class="contact-left">
      <div class="contact-image" aria-hidden="true">
        <img src={bgContact.src} alt="" class="contact-image-img" />
      </div>
      <div class="contact-brand  top-1/5 left-1/4 lg:top-1/5 lg:left-1/5">
        <span class="contact-chile text-pink-500 dark:text-gold z-10">Chile</span>
        <Logo class="contact-logo text-white" />
        <span class="contact-name text-pink-500 dark:text-gold">Camilo Chav&eacute;z</span>
      </div>
    </div>

    <div class="contact-right">
      <h1 class="contact-title">
        Hablemos y Descorchemos
      </h1>
      <p class="contact-desc">
        Agendemos una reunión de 30 minutos para ver la factibilidad de realizar
        alg&uacute;n proyecto juntos.
      </p>
      <a
        href="https://calendly.com/camilochavez/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-cta inline-flex items-center justify-center bg-white dark:bg-blue-500 py-4! px-8! rounded-4xl text-blue-500 dark:text-white hover:scale-102 transition-transform duration-500 uppercase font-semibold tracking-wider hover:shadow-blue-950 hover:shadow-lg text-sm"
      >
        <CalendlyIcon class="w-7 h-7 mr-2!" />
        Agender una reunión
      </a>
    </div>
  </div>

  
</section>

<style>
  .contact {
    position: relative;
    overflow: hidden;
  }

  .contact-inner {
    display: flex;
    flex-direction: column-reverse;
    min-height: 100svh;
  }

  @media (min-width: 1024px) {
    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Right column ─────────────────────────── */
  .contact-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 5vw, 4rem);
    text-align: center;
  }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 12vw, 10rem);
    font-weight: 400;
    line-height: 0.6;
    margin-bottom: 1.5rem;
  }

  .contact-desc {
    font-family: var(--font-serif);
    font-size: clamp(0.875rem, 1.5vw, 1.125rem);
    margin-bottom: 2.5rem;
    max-width: 32rem;
  }

  .contact-cta {
    font-family: var(--font-sans);
  }

  /* ── Left column ──────────────────────────── */
  .contact-left {
    position: relative;
    height: 60svh;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .contact-left {
      height: 100svh;
    }
  }

  .contact-image {
    width: 100%;
    height: 100%;
  }

  .contact-image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .contact-brand {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-chile,
  .contact-name {
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 7rem);
    font-weight: 400;
    line-height: 0;

  }

  .contact-logo {
    width: clamp(60px, 20vw, 300px);
    height: auto;
  }
</style>
