---
import Linkedin from "../icons/linkedin.astro";
import Instagram from "../icons/instagram.astro";
---

<footer id="footer" class="footer bg-olive-950 text-muted text-xs">
  <div class="w-full flex flex-col md:flex-row justify-between items-center gap-2 text-center md:text-left mx-auto px-20! py-4!">
    <div class="footer-left">
      <p>&copy; {new Date().getFullYear()} En Una Copa. Todos los derechos reservados.</p>
    </div>

    <div class="footer-center">
      <p>
        Hecho con <span class="text-pink-500 dark:text-gold" aria-hidden="true">&hearts;</span> por
        <a href="https://www.rodfuentealba.com" target="_blank" rel="noopener noreferrer" class="text-pink-500 dark:text-gold">rodFuentealba</a>
      </p>
    </div>

    <div class="footer-right">
      <a href="https://www.linkedin.com/in/camilo-ch%C3%A1vez-ram%C3%ADrez-2b060a94/" target="_blank" rel="noopener noreferrer" class="footer-social text-pink-500 dark:text-gold hover:scale-110 transition-all" aria-label="LinkedIn">
        <Linkedin class="w-4 h-4 hover:text-pink-500 dark:hover:text-gold" />
      </a>
      <a href="https://www.instagram.com/camilocram" target="_blank" rel="noopener noreferrer" class="footer-social text-pink-500 dark:text-gold hover:scale-110 transition-all hover:text-pink-500 dark:hover:text-gold" aria-label="Instagram">
        <Instagram class="w-4 h-4 hover:text-pink-500 dark:hover:text-gold" />
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: 0.5rem;
    font-family: var(--font-sans);
  }

  .footer-left,
  .footer-center,
  .footer-right {
    display: flex;
    align-items: center;
  }

  .footer-left p,
  .footer-center p {
    margin: 0;
  }

  .footer-right {
    gap: 1rem;
  }

  .footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    transition: color 0.2s, transform 0.2s;
  }
</style>

<script>
import { footerEntry } from '../../animations'

footerEntry()
</script>
