---
import bgCollab from "../../assets/images/bgCollab.webp";
import { useTranslations } from '../../i18n'

const { locale } = Astro.props
const { t } = useTranslations(locale)
---

<section
  id="collab"
  class="relative w-full min-h-screen flex items-center bg-fixed bg-cover bg-center bg-no-repeat"
  style={`background-image: url(${bgCollab.src})`}
>
  <div class="absolute inset-0 bg-linear-to-t from-black via-black/0 to-transparent" aria-hidden="true"></div>

  <div class="relative w-full pb-[50vh]">
    <div class="container mx-auto px-4 text-center">
      <p class="collab-medium text-white mix-blend-difference">
        {t('collab.p1')}
      </p>

      <h2 class="collab-display leading-12! lg:leading-20!">
        <span class="text-white mix-blend-difference">{t('collab.heading1')}</span>
        <span class="md:text-xl lg:text-9xl! text-white mix-blend-difference">{t('collab.heading2')}</span>
      </h2>

      <p class="collab-small text-olive-400 dark:text-white">
        {t('collab.p2')}
      </p>
    </div>
  </div>
</section>

<style>
  .collab-medium {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2vw, 1.25rem);
    margin-bottom: clamp(1.5rem, 12vw, 10rem);
  }

  .collab-display {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 20vw, 15rem);
    font-weight: 400;
    display: flex;
    flex-direction: column;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  .collab-small {
    font-family: var(--font-serif);
    font-size: clamp(0.8125rem, 1.5vw, 1rem);
    line-height: 1.75;
  }
</style>

<script>
import { collabEntry } from '../../animations'

collabEntry()
</script>
