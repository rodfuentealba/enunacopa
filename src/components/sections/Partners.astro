---
import bgPartners from "../../assets/images/bgPartners.webp";
import { useTranslations } from '../../i18n'

const { locale } = Astro.props
const { t, tArray } = useTranslations(locale)

interface Partner {
    firstLetter: string
    restOfTitle: string
    dots: string[]
}

const partners = tArray<Partner>('partners.tiers')
const intro = t('partners.intro')
---

<section
    id="partners"
    class="relative w-full min-h-screen overflow-hidden flex items-center"
>
    <div class="absolute inset-0 z-0" aria-hidden="true">
        <img
            src={bgPartners.src}
            alt=""
            class="w-full h-full object-cover object-[65%_center] lg:object-center"
            loading="lazy"
        />
    </div>

    <div class="relative z-10 w-full">
        <div class="container mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 md:gap-50 min-h-screen">
                <div class="flex flex-col items-center justify-end md:pb-30!">
                    <p
                        class="text-sm text-gray-300 dark:text-gray-300 max-w-md text-center md:text-left leading-relaxed"
                        set:html={intro}
                    >
                    </p>
                </div>

                <div
                    class="flex flex-col items-center justify-center gap-12"
                >
                    {
                        partners.map((partner) => (
                            <div class="text-center md:text-left w-full max-w-md">
                                <h3 class="part-role text-emerald-300 dark:text-emerald-500">
                                    <span class="part-role-s text-emerald-300 dark:text-emerald-500">
                                        {partner.firstLetter}
                                    </span>
                                    {partner.restOfTitle}
                                </h3>
                                {
                                    partner.dots.map((dot: string) => (
                                        <p class="ser-serif text-md text-gray-300 dark:text-gray-300 max-w-md" set:html={dot}>
                                        </p>
                                    ))
                                }
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .part-role {
        font-family: var(--font-sans);
        font-size: clamp(2rem, 4vw, 4rem);
        font-weight: 600;
        line-height: 1;
    }

    .part-role-s {
        font-family: var(--font-display);
        font-size: 1.5em;
        display: inline-block;
        margin-right: -10px;
    }
</style>

<script>
import { partnersEntry } from '../../animations'

partnersEntry()
</script>
